# =====================================================================
#  Login con Google (OIDC) — variables de entorno
# ---------------------------------------------------------------------
#  1) Copia este archivo como .env  (en la misma carpeta):
#         cp .env.example .env        (Linux/macOS / Git Bash)
#         copy .env.example .env      (Windows CMD)
#  2) Crea las credenciales gratis en Google Cloud Console y pégalas abajo.
#     Guía paso a paso:  GOOGLE_LOGIN_SETUP.md
#  3) Levanta el stack:  docker compose -f docker-compose.full.yml up --build
#
#  docker compose lee automáticamente este .env para rellenar las variables
#  del servicio api/worker en docker-compose.full.yml.
# =====================================================================

# --- Credenciales del cliente OAuth 2.0 (obligatorias para que aparezca Google) ---
GOOGLE_OIDC_CLIENT_ID=PEGA_AQUI_TU_CLIENT_ID.apps.googleusercontent.com
GOOGLE_OIDC_CLIENT_SECRET=PEGA_AQUI_TU_CLIENT_SECRET

# --- Quién entra como STAFF (administrador del dashboard) ---
# Opción A (recomendada / controlada): lista de correos exactos separados por coma.
GOOGLE_OIDC_STAFF_EMAILS=tu_correo@gmail.com

# Opción B (abierta): cualquier usuario cuyo correo pertenezca a estos dominios
# entra como staff. Útil para demo. Déjalo vacío si usas solo la opción A.
# ¡OJO! gmail.com deja entrar como admin a CUALQUIER cuenta Gmail. Úsalo solo en demo.
GOOGLE_OIDC_STAFF_DOMAINS=
